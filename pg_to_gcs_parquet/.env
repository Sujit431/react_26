PG_HOST=34.93.81.117
PG_PORT=5432
PG_DATABASE=exportdb
PG_SCHEMA=public
PG_USERNAME=postgres
PG_PASSWORD=isu12345

GCS_BUCKET=prod-isurecon
GCS_PREFIX=iceberg
GCS_PROJECT_ID=iserveustaging
GOOGLE_APPLICATION_CREDENTIALS=service-account.json

# ─── Parquet Settings ─────────────────────────────────────────
PARQUET_COMPRESSION=snappy
PARQUET_ROW_GROUP_SIZE=250000

# ─── DSBulk Settings ──────────────────────────────────────────
