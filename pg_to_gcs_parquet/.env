DSBULK_MAX_CONCURRENT_FILES=8
DSBULK_MAX_PER_SECOND=10000
CSV_STAGING_DIR=/tmp/cass_export

# ─── API (optional — for dynamic keyspace/table discovery) ────
CASS_EXPORT_API=https://services-v1.Centoxy.online/cass-export
